@startuml
start

:Родитель обращается к администратору;
:Администратор создаёт заявку в CRM;

:Администратор выполняет поиск ученика;

if (Ученик найден в CRM?) then (да)
  :Администратор выбирает ученика;
else (нет)
  :Администратор регистрирует нового ученика;
  :Вводит ФИО ученика, дату рождения;
  :Вводит имя родителя, телефон, email;
  :CRM создаёт учётную запись ученика;
endif

:Администратор проверяет\nналичие свободных мест на курсе;

if (Есть свободные места?) then (да)
  :Администратор связывается с родителем;
  :Уточняет курс, группу, время;
  
  if (Родитель согласен?) then (да)
    :Администратор записывает ученика на занятие;
    :Статус заявки = ЗАПИСАН;
    :Статус занятия = ЗАПЛАНИРОВАНО;
    :Администратор уведомляет родителя;
    
    :Преподаватель проводит занятие;
    :Преподаватель отмечает посещаемость;
    :Статус занятия = ПРОВЕДЕНО;
    :В CRM сохраняется посещаемость и тема занятия;
    
    stop
  else (нет)
    :Администратор закрывает заявку\n(статус = ОТКЛОНЕНА);
    stop
  endif
  
else (нет)
  :Администратор предлагает\nальтернативные группы;
  
  if (Родитель согласен на альтернативу?) then (да)
    :Администратор записывает\nна альтернативное занятие;
    :Уведомляет родителя;
    :Преподаватель проводит занятие;
    :Отмечает посещаемость;
    stop
  else (нет)
    :Администратор закрывает заявку\n(статус = ОТКЛОНЕНА);
    stop
  endif
endif

@enduml
