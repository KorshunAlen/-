@startuml
skinparam classAttributeIconSize 0

class Пользователь {
  - id: UUID
  - логин: string
  - пароль: string
  - фамилия: string
  - имя: string
  - отчество: string
  - телефон: string
  - email: string
  + авторизоваться()
  + сменитьПароль()
}

class Администратор {
  + зарегистрироватьУченика()
  + заблокироватьПользователя()
  + записатьНаЗанятие()
  + отменитьЗапись()
  + сделатьРассылку()
  + управлятьГруппой()
}

class Преподаватель {
  + вестиЗанятие()
  + отметитьПосещаемость()
}

class Ученик {
  - датаРождения: Date
  - школа: string
  - имяРодителя: string
  - телефонРодителя: string
  - emailРодителя: string
  + просмотретьРасписание()
  + сдатьДомашнееЗадание()
}

class Курс {
  - id: UUID
  - название: string
  - описание: string
  - стоимость: decimal
  + добавить()
  + редактировать()
}

class Группа {
  - id: UUID
  - название: string
  - максимальноеКоличествоУчеников: int
  + добавитьУченика()
  + удалитьУченика()
}

class Занятие {
  - id: UUID
  - датаВремя: DateTime
  - статус: СтатусЗанятия
}

class Расписание {
  + получитьРасписаниеГруппы()
  + получитьРасписаниеПреподавателя()
}

class Заявка {
  - id: UUID
  - датаСоздания: DateTime
  - статус: СтатусЗаявки
  + одобрить()
  + отклонить()
}

enum СтатусЗанятия {
  ЗАПЛАНИРОВАНО
  ПРОВЕДЕНО
  ОТМЕНЕНО
}

enum СтатусЗаявки {
  НОВАЯ
  В_ОБРАБОТКЕ
  ОДОБРЕНА
  ОТКЛОНЕНА
}

' Наследование
Пользователь <|-- Администратор
Пользователь <|-- Преподаватель
Пользователь <|-- Ученик

' Ассоциации
Администратор --> Заявка : обрабатывает
Администратор --> Расписание : управляет
Администратор --> Группа : управляет

Преподаватель --> Группа : ведёт
Преподаватель --> Занятие : проводит

Ученик --> Группа : посещает
Ученик --> Заявка : создаёт (через администратора)

Курс --> Группа : "1..*"
Группа --> Занятие : "1..*"
Расписание --> Занятие : формирует

@enduml
